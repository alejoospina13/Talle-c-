using System;

class Program
{
    static void Main(string[] args)
    {
        string[] nombres = new string[5];
        int[] cantidades = new int[5];

        for (int i = 0; i < 5; i++)
        {
            Console.Write("Ingrese el nombre del medicamento " + (i + 1) + ": ");
            nombres[i] = Console.ReadLine();

            Console.Write("Ingrese la cantidad disponible: ");
            cantidades[i] = int.Parse(Console.ReadLine());
        }

        Console.Clear();

        Console.WriteLine("====================================");
        Console.WriteLine("      INVENTARIO DE MEDICAMENTOS    ");
        Console.WriteLine("====================================\n");

        for (int i = 0; i < 5; i++)
        {
            Console.WriteLine((i + 1) + ". " + nombres[i] + " - " + cantidades[i] + " unidades");
        }

        Console.WriteLine("...");

        int menor = cantidades[0];
        int pos = 0;

        for (int i = 1; i < 5; i++)
        {
            if (cantidades[i] < menor)
            {
                menor = cantidades[i];
                pos = i;
            }
        }

        Console.WriteLine("\n====================================");
        Console.WriteLine("⚠ Menor stock: " + nombres[pos] + " (" + menor + ")");
        Console.WriteLine("====================================");
    }
}
